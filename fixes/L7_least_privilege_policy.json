{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ScopedReceiptsBucketAccess",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::dvsa-website-abd-544719091426-us-east-1/receipts/*"
    },
    {
      "Sid": "ReadOnlyDvsaUsersTable",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem"
      ],
      "Resource": "arn:aws:dynamodb:us-east-1:544719091426:table/DVSA-USERS-DB"
    },
    {
      "Sid": "ReadOnlyDvsaOrdersTable",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem"
      ],
      "Resource": "arn:aws:dynamodb:us-east-1:544719091426:table/DVSA-ORDERS-DB"
    },
    {
      "Sid": "SendReceiptEmailOnly",
      "Effect": "Allow",
      "Action": [
        "ses:SendEmail",
        "ses:SendRawEmail"
      ],
      "Resource": "*"
    },
    {
      "Sid": "OwnLogsOnly",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:us-east-1:544719091426:log-group:/aws/lambda/DVSA-SEND-RECEIPT-EMAIL:*"
    }
  ]
}
